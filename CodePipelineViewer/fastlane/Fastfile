default_platform(:mac)

platform :mac do
  desc "Build and notarize .dmg for GitHub Release"
  lane :github_release do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )

    match(type: "developer_id", readonly: true, api_key: api_key)

    version = ENV["RELEASE_VERSION"]
    if version
      increment_version_number(
        version_number: version,
        xcodeproj: "CodePipelineViewer.xcodeproj"
      )
    end

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M%S"),
      xcodeproj: "CodePipelineViewer.xcodeproj"
    )

    build_app(
      scheme: "CodePipelineViewer",
      export_method: "developer-id",
      output_directory: "build",
      output_name: "CodePipelineViewer",
      skip_package_pkg: true,
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Developer ID Application' PROVISIONING_PROFILE_SPECIFIER='match Direct com.keenankaufman.codepipeline-viewer macos'"
    )

    dmg_path = "build/CodePipelineViewer-#{version || 'dev'}.dmg"

    sh("hdiutil create -volname 'CodePipeline Viewer' -srcfolder '../build/CodePipelineViewer.app' -ov -format UDZO '../#{dmg_path}'")

    notarize(
      package: dmg_path,
      bundle_id: "com.keenankaufman.codepipeline-viewer",
      api_key: api_key,
      print_log: true
    )

    sh("xcrun stapler staple '../#{dmg_path}'")

    sh("echo 'DMG_PATH=#{dmg_path}' >> $GITHUB_OUTPUT") if ENV["GITHUB_OUTPUT"]
  end
end
